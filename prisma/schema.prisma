generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider     = "sqlite"
  relationMode = "prisma"
}

model PlatformConfig {
  id                   String   @id @default(cuid())
  siteName             String   @default("Green Axis S.A.S.")
  siteUrl              String?
  siteSlogan           String?
  siteDescription      String?
  logoUrl              String?
  faviconUrl           String?
  companyName          String?
  companyAddress       String?
  companyPhone         String?
  companyEmail         String?
  notificationEmail    String?
  facebookUrl          String?
  instagramUrl         String?
  twitterUrl           String?
  linkedinUrl          String?
  tiktokUrl            String?
  youtubeUrl           String?
  footerText           String?
  socialText           String?  @default("Síguenos en nuestras redes")
  whatsappNumber       String?
  whatsappMessage      String?  @default("¡Hola! Me gustaría obtener información sobre sus servicios ambientales.")
  whatsappShowBubble   Boolean  @default(true)
  aboutImageUrl        String?
  aboutTitle           String?  @default("Comprometidos con el futuro del planeta")
  aboutDescription     String?
  aboutYearsExperience String?  @default("15")
  aboutYearsText       String?  @default("Años protegiendo el medio ambiente")
  aboutStats           String?
  aboutFeatures        String?
  aboutSectionEnabled  Boolean  @default(true)
  aboutBadge           String?  @default("Sobre Nosotros")
  aboutBadgeColor      String?  @default("#6BBE45")
  showMapSection       Boolean  @default(true)
  metaKeywords         String?
  googleAnalytics      String?
  googleMapsEmbed      String?
  primaryColor         String?  @default("#6BBE45")
  portfolioEnabled     Boolean  @default(false)
  portfolioTitle       String?  @default("Descarga Nuestro Portafolio Corporativo")
  portfolioUrl         String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Service {
  id               String   @id @default(cuid())
  title            String
  slug             String?  @unique
  description      String?
  shortBlocks      String?
  content          String?
  blocks           String?
  icon             String?
  imageUrl         String?
  order            Int      @default(0)
  active           Boolean  @default(true)
  featured         Boolean  @default(false)
  showSummary      Boolean  @default(true)
  portfolioEnabled Boolean  @default(false)
  portfolioTitle   String?  @default("Descarga el Portafolio de Servicios Ambientales")
  portfolioUrl     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model News {
  id                 String    @id @default(cuid())
  title              String
  slug               String    @unique
  excerpt            String?
  content            String
  imageUrl           String?
  author             String?
  published          Boolean   @default(false)
  featured           Boolean   @default(false)
  publishedAt        DateTime?
  blocks             String?
  showCoverInContent Boolean   @default(true)
  imageCaption       String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model SiteImage {
  id          String   @id @default(cuid())
  key         String?  @unique
  label       String
  description String?
  url         String
  alt         String?
  category    String?
  hash        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CarouselSlide {
  id               String   @id @default(cuid())
  title            String?
  subtitle         String?
  description      String?
  imageUrl         String
  buttonText       String?
  buttonUrl        String?
  linkUrl          String?
  gradientEnabled  Boolean  @default(true)
  animationEnabled Boolean  @default(true)
  gradientColor    String?
  order            Int      @default(0)
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model LegalPage {
  id         String   @id @default(cuid())
  slug       String   @unique
  title      String
  content    String
  blocks     String?
  manualDate String?
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  subject   String?
  message   String
  consent   Boolean  @default(false)
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SocialFeedConfig {
  id          String   @id @default(cuid())
  platform    String
  embedCode   String?
  accessToken String?
  pageId      String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("admin")
  status    String   @default("pendiente")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AboutPage {
  id                    String   @id @default(cuid())
  heroTitle             String?  @default("Quiénes Somos")
  heroSubtitle          String?  @default("Comprometidos con el medio ambiente")
  heroImageUrl          String?
  historyTitle          String?  @default("Nuestra Historia")
  historyContent        String?
  historyImageUrl       String?
  missionTitle          String?  @default("Nuestra Misión")
  missionContent        String?
  visionTitle           String?  @default("Nuestra Visión")
  visionContent         String?
  valuesTitle           String?  @default("Nuestros Valores")
  valuesContent         String?
  teamTitle             String?  @default("Nuestro Equipo")
  teamEnabled           Boolean  @default(false)
  teamMembers           String?
  whyChooseTitle        String?  @default("¿Por Qué Elegirnos?")
  whyChooseContent      String?
  ctaTitle              String?  @default("¿Listo para trabajar con nosotros?")
  ctaSubtitle           String?  @default("Contáctanos y descubre cómo podemos ayudarte")
  ctaButtonText         String?  @default("Contáctanos")
  ctaButtonUrl          String?  @default("/contacto")
  statsEnabled          Boolean  @default(true)
  statsContent          String?
  certificationsEnabled Boolean  @default(false)
  certificationsContent String?
  showLocationSection   Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
